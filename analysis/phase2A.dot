// ============================================================
// King of Rubble — Phase 2-A 状态机（60546 分支，DragonForm 起始）
// 触发：HasSE(60546)（P1-B 死亡演出后由外部注入）
// 源：761000_battle.dec.lua line 266-546 (权重池)
//
// P2-A 相较 P1-B：
//   • 普攻升级 slot 20-24（动画换 A001，行为更凶）
//   • 红刀链换成 P2 版 slot 30 → 31 → 32（无追击段 slot 13）
//   • 新增飞扑 slot 37（Interrupt 触发点 5035）
//   • 新增甩尸块 slot 35/45（走位/远距变体）
//   • 乱舞升级为 slot 36
//   • 吸球链保留（slot 15-16-17-18 跨阶段共用）
//
// Interrupt 反应表见 line 1873-2145 (60545/60546 共用)
// ============================================================
digraph P2A_StateMachine {
    graph [rankdir=LR, fontname="Consolas", splines=spline, nodesep=0.4, ranksep=1.0,
           bgcolor="#fafafa", labelloc="t", fontsize=12,
           label="Phase 2-A（60546 — DragonForm 起始）\n招式家族全面升级，红刀链缩短为 3 段，新增飞扑/甩尸块\n🔄 AfterAttack 后队列空，触发新一轮 Battle Decision"];
    node  [fontname="Consolas", fontsize=10, shape=box, style="rounded,filled"];
    edge  [fontname="Consolas", fontsize=8];

    { rank=source;
    hub [label="⚙ Battle Decision\n\n【顶层优先级】\n1. HasSE(60566) → slot 16/17\n2. HP<0.55 → slot 38\n3. HP<0.85 → 中血距离矩阵\n4. 否则高血距离矩阵",
         shape=hexagon, fillcolor="#fff7d6"];
    }

    // ==================== 二阶普攻起手池 ====================
    subgraph cluster_normal {
        label="二阶普攻池（slot 20-24，动画换 A001）";
        style="rounded,filled"; fillcolor="#f5e0d8"; color="#b98a7a";

        n20 [label="二阶近战A\n─────\nslot 20  |  ID 3000\n5025帧\n★两栖", fillcolor="#f5d8c8", color="#cc3333", penwidth=2];
        n21 [label="二阶近战B\n─────\nslot 21  |  ID 3001\n5026帧\n★两栖", fillcolor="#f5d8c8", color="#cc3333", penwidth=2];
        n22 [label="二阶横扫\n─────\nslot 22  |  ID 3005/3010\n5027/5028/5029帧", fillcolor="#f5d8c8"];
        n23 [label="二阶重击\n─────\nslot 23  |  ID 3012\n5030帧", fillcolor="#f5d8c8"];
        n24 [label="二阶收尾\n─────\nslot 24  |  ID 3013\n5031帧", fillcolor="#f5d8c8"];
    }

    // ==================== 走位（跨阶段共用）====================
    subgraph cluster_reposition {
        label="走位池";
        style="rounded,filled"; fillcolor="#f0f4fb"; color="#7a97b9";

        n40 [label="靠近\nslot 40", fillcolor="#dfe7f5"];
        n41 [label="侧步\nslot 41", fillcolor="#dfe7f5"];
        n42 [label="侧步\nslot 42", fillcolor="#dfe7f5"];
        n45 [label="StepSafety\n(左/右)\nslot 45", fillcolor="#dfe7f5"];
    }

    // ==================== 二阶红刀链 ====================
    subgraph cluster_redsword {
        label="🔴 二阶红刀链（3 段版，无追击）";
        style="rounded,filled"; fillcolor="#fdf0f0"; color="#cc3366";

        n30 [label="红刀·抬手\n─────\nslot 30  |  ID 3015\n\n入口: 60551 无 60565", fillcolor="#ffd8e0", color="#cc3366", penwidth=2];
        n31 [label="红刀·架势\n─────\nslot 31  |  ID 3016\n\n入口: 60551 + 60565", fillcolor="#ffd8e0", color="#cc3366", penwidth=2];
        n32 [label="红刀·释放\n─────\nslot 32  |  ID 3017\n\n入口: 60551 + 60565 + 60567", fillcolor="#ffd8e0", color="#cc3366", penwidth=2];
    }

    // ==================== 吸球链（跨阶段共用 slot）====================
    subgraph cluster_ball {
        label="🔵 吸球链（跨阶段共用）";
        style="rounded,filled"; fillcolor="#f0f0fd"; color="#3366cc";

        n15 [label="吸球·启动\nslot 15", fillcolor="#d8e0ff", color="#3366cc", penwidth=2];
        n16 [label="吸球·释放1次\nslot 16  (dist>12.5)", fillcolor="#d8e0ff", color="#3366cc", penwidth=2];
        n17 [label="吸球·释放2次\nslot 17  (dist≤12.5)", fillcolor="#d8e0ff", color="#3366cc", penwidth=2];
        n18 [label="超大球\nslot 18 (退化后大招)", fillcolor="#c8d0ff", color="#3366cc", penwidth=2.5];
    }

    // ==================== 二阶特有招 ====================
    subgraph cluster_p2_special {
        label="Phase 2 特有招";
        style="rounded,filled"; fillcolor="#fbf0e0"; color="#cc9966";

        n35 [label="甩尸块\nslot 35  |  ID 3020/3021\n(左右分支)\n5033帧", fillcolor="#ffe0c8"];
        n36 [label="乱舞（二阶）\nslot 36  |  ID 3022\n5034帧起手\n冷却 40s", fillcolor="#ffd8b0"];
        n37 [label="飞扑\nslot 37  |  ID 3034\n5035帧起手 (危险预警)\n冷却 30s", fillcolor="#ffcca0", color="#cc5533", penwidth=2];
    }

    // ==================== 派生招 ====================
    subgraph cluster_derivatives {
        label="派生招（Interrupt append）";
        style="rounded,filled"; fillcolor="#fff0f0"; color="#cc6666";

        d3007 [label="横扫近距\nID 3007", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3011 [label="180°回身斩\nID 3011\n(P2 特有)", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3002 [label="重击追击\nID 3002", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3023 [label="远程追击\nID 3023\n(飞扑/乱舞派生)", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3033 [label="飞扑追击\nID 3033", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3039 [label="飞扑终结\nID 3039", fillcolor="#ffcccc", color="#cc3333", penwidth=2];
    }

    { rank=sink;
    aa [label="🌬 AfterAttack", shape=note, fillcolor="#e8f8ff"];
    }

    // ==================== 权重抽签边 ====================
    hub -> n20 [label="w:0~100"];
    hub -> n21 [label="w:0~100"];
    hub -> n22 [label="w:0~100"];
    hub -> n23 [label="w:0~100"];
    hub -> n24 [label="w:0~200\n(贴脸高)"];

    hub -> n35 [label="w:0~200", color="#cc9966"];
    hub -> n36 [label="w:0~200\n(中远距)", color="#cc9966"];
    hub -> n37 [label="w:0~200\n(中远距)", color="#cc5533", penwidth=1.5];

    hub -> n15 [label="w:200 (dist>12.5)", color="#3366cc"];
    hub -> n18 [label="🟣 HP<0.55\nSE 强制", color="#8833cc", penwidth=2.5];

    hub -> n40 [label="w:50", color="#4477bb"];
    hub -> n41 [label="w:0~75", color="#4477bb"];
    hub -> n42 [label="w:0~75", color="#4477bb"];
    hub -> n45 [label="w:0~200", color="#4477bb"];

    // 二阶红刀链入口
    hub -> n30 [label="🟣 60551 无 60565", color="#8833cc", penwidth=2.5];

    // 吸球链
    hub -> n16 [label="🟣 60566 + dist>12.5", color="#8833cc", penwidth=2.5];
    hub -> n17 [label="🟣 60566 + dist≤12.5", color="#8833cc", penwidth=2.5];

    // ==================== SE 强制转移 ====================
    n30 -> hub [label="🟣 播完加 60565 → 强制 slot 31", color="#8833cc", penwidth=2, constraint=false];
    n31 -> hub [label="🟣 播完加 60567 → 强制 slot 32", color="#8833cc", penwidth=2, constraint=false];
    n32 -> hub [label="🟣 播完清 SE，回归自由抽签", color="#8833cc", penwidth=2, style=dashed, constraint=false];

    n15 -> hub [label="🟣 播完加 60566", color="#8833cc", penwidth=2, constraint=false];
    n17 -> hub [label="🟣 播完可能加 60553 → slot 18", color="#8833cc", penwidth=2, style=dashed, constraint=false];

    // ==================== Interrupt append 边 ====================
    n20 -> d3002 [label="🔥 5025帧\n近 + rand≤70", color="#cc3333", penwidth=2];
    n20 -> n21   [label="🔥 5025帧\n中(派生 3001)", color="#cc3333", penwidth=2];
    n21 -> d3002 [label="🔥 5026帧\n近", color="#cc3333", penwidth=2];
    n21 -> n21   [label="🔥 5026帧\n中(自派生)", color="#cc3333", penwidth=2];

    n22 -> d3007 [label="🔥 5027帧\n近 + rand≤70", color="#cc3333", penwidth=2];
    n22 -> d3011 [label="🔥 5029帧\n中(180°回身)", color="#cc3333", penwidth=2];
    n22 -> d3002 [label="🔥 5028/5029帧\n近", color="#cc3333", penwidth=2];

    n23 -> d3002 [label="🔥 5030帧\n近 + rand≤70", color="#cc3333", penwidth=2];

    // 二阶特有的 Interrupt
    n36 -> d3023 [label="🔥 5034帧\n前方40m内\n(乱舞后接远程)", color="#cc3333", penwidth=2];
    n37 -> d3033 [label="🔥 5035帧\n无 60555 → 追击", color="#cc3333", penwidth=2];
    n37 -> d3039 [label="🔥 5035帧\n有 60555 + 前方 → 终结\n(rand≤70)", color="#cc3333", penwidth=2];

    // ==================== AfterAttack 汇聚 ====================
    n20 -> aa [style=dashed, color="#888888"];
    n21 -> aa [style=dashed, color="#888888"];
    n22 -> aa [style=dashed, color="#888888"];
    n23 -> aa [style=dashed, color="#888888"];
    n24 -> aa [style=dashed, color="#888888"];
    n30 -> aa [style=dashed, color="#888888"];
    n31 -> aa [style=dashed, color="#888888"];
    n32 -> aa [style=dashed, color="#888888"];
    n15 -> aa [style=dashed, color="#888888"];
    n16 -> aa [style=dashed, color="#888888"];
    n17 -> aa [style=dashed, color="#888888"];
    n18 -> aa [style=dashed, color="#888888"];
    n35 -> aa [style=dashed, color="#888888"];
    n36 -> aa [style=dashed, color="#888888"];
    n37 -> aa [style=dashed, color="#888888"];
    d3007 -> aa [style=dashed, color="#888888"];
    d3011 -> aa [style=dashed, color="#888888"];
    d3002 -> aa [style=dashed, color="#888888"];
    d3023 -> aa [style=dashed, color="#888888"];
    d3033 -> aa [style=dashed, color="#888888"];
    d3039 -> aa [style=dashed, color="#888888"];
    n40 -> aa [style=dashed, color="#888888"];
    n41 -> aa [style=dashed, color="#888888"];
    n42 -> aa [style=dashed, color="#888888"];
    n45 -> aa [style=dashed, color="#888888"];

    // ==================== 图例 ====================
    subgraph cluster_legend {
        label="图例"; style="rounded,dashed"; color="#aaaaaa";
        rank=sink;
        leg1 [label="■ 黑实线 = 权重抽签", shape=plaintext];
        leg2 [label="━ 粗红线 = Interrupt append", shape=plaintext, fontcolor="#cc3333"];
        leg3 [label="🟣 紫粗线 = SE 强制 (combo chain)", shape=plaintext, fontcolor="#8833cc"];
        leg4 [label="┈ 虚灰线 = 打完 → AfterAttack", shape=plaintext];
    }
}
