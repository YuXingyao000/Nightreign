// ============================================================
// King of Rubble — Phase 2-B 状态机（60545 分支，激烈化）
// 触发：HasSE(60545)（Act38 长吼叫首次释放后）
// 源：761000_battle.dec.lua line 59-265 (权重池)
//
// P2-B 相较 P2-A：
//   • 长吼叫 slot 38 退化为常规大招（HasSE(60553) 触发）
//   • HP<0.2 处决权重（slot 18 强制 100，超大球退化后的处决招）
//   • 距离矩阵权重整体上调（更激进）
//   • Interrupt 反应表相同（60545/60546 共用 line 1873-2145）
// ============================================================
digraph P2B_StateMachine {
    graph [rankdir=LR, fontname="Consolas", splines=spline, nodesep=0.4, ranksep=1.0,
           bgcolor="#fafafa", labelloc="t", fontsize=12,
           label="Phase 2-B（60545 — DragonForm 激烈化）\n新增：长吼叫大招化 + HP<0.2 处决\n🔄 AfterAttack 后队列空，触发新一轮 Battle Decision"];
    node  [fontname="Consolas", fontsize=10, shape=box, style="rounded,filled"];
    edge  [fontname="Consolas", fontsize=8];

    { rank=source;
    hub [label="⚙ Battle Decision\n\n【顶层优先级】\n1. HasSE(60566) → slot 16/17\n2. HP<0.2 无 60585 → slot 18 (处决)\n3. HasSE(60553) → slot 38 (长吼叫)\n4. HasSE(60551) → 二阶红刀链\n5. 距离段 × 朝向 → 权重池",
         shape=hexagon, fillcolor="#fff7d6"];
    }

    // ==================== 二阶普攻起手池（激进版）====================
    subgraph cluster_normal {
        label="二阶普攻池（权重整体上调）";
        style="rounded,filled"; fillcolor="#f5d8d8"; color="#b97a7a";

        n20 [label="二阶近战A\nslot 20 | ID 3000\n★两栖", fillcolor="#f5c8c8", color="#cc3333", penwidth=2];
        n21 [label="二阶近战B\nslot 21 | ID 3001\n★两栖", fillcolor="#f5c8c8", color="#cc3333", penwidth=2];
        n22 [label="二阶横扫\nslot 22 | ID 3005/3010", fillcolor="#f5c8c8"];
        n23 [label="二阶重击\nslot 23 | ID 3012", fillcolor="#f5c8c8"];
        n24 [label="二阶收尾\nslot 24 | ID 3013", fillcolor="#f5c8c8"];
    }

    subgraph cluster_reposition {
        label="走位池";
        style="rounded,filled"; fillcolor="#f0f4fb"; color="#7a97b9";

        n40 [label="靠近\nslot 40", fillcolor="#dfe7f5"];
        n41 [label="侧步\nslot 41", fillcolor="#dfe7f5"];
        n42 [label="侧步\nslot 42", fillcolor="#dfe7f5"];
        n45 [label="StepSafety\nslot 45", fillcolor="#dfe7f5"];
    }

    // ==================== 二阶红刀链 ====================
    subgraph cluster_redsword {
        label="🔴 二阶红刀链（同 P2-A）";
        style="rounded,filled"; fillcolor="#fdf0f0"; color="#cc3366";

        n30 [label="红刀·抬手\nslot 30", fillcolor="#ffd8e0", color="#cc3366", penwidth=2];
        n31 [label="红刀·架势\nslot 31", fillcolor="#ffd8e0", color="#cc3366", penwidth=2];
        n32 [label="红刀·释放\nslot 32", fillcolor="#ffd8e0", color="#cc3366", penwidth=2];
    }

    // ==================== 吸球链 ====================
    subgraph cluster_ball {
        label="🔵 吸球链";
        style="rounded,filled"; fillcolor="#f0f0fd"; color="#3366cc";

        n15 [label="吸球·启动\nslot 15", fillcolor="#d8e0ff", color="#3366cc", penwidth=2];
        n16 [label="吸球·释放1次\nslot 16", fillcolor="#d8e0ff", color="#3366cc", penwidth=2];
        n17 [label="吸球·释放2次\nslot 17", fillcolor="#d8e0ff", color="#3366cc", penwidth=2];
        n18 [label="超大球（处决化）\nslot 18\n\nHP<0.2 强制 w=100\n作为血低终结招",
             fillcolor="#c8d0ff", color="#3366cc", penwidth=2.5];
    }

    // ==================== P2 特有 + P2-B 独有大招 ====================
    subgraph cluster_p2b_special {
        label="P2 特有招 + P2-B 大招";
        style="rounded,filled"; fillcolor="#ffd8b0"; color="#cc5533";

        n35 [label="甩尸块\nslot 35", fillcolor="#ffe0c8"];
        n36 [label="乱舞（二阶）\nslot 36", fillcolor="#ffd8b0"];
        n37 [label="飞扑\nslot 37\n5035帧起手", fillcolor="#ffcca0", color="#cc5533", penwidth=2];
        n38 [label="⚡ 长吼叫（大招化）\nslot 38 | ID 3038\n5037帧起手\n\n入口: HasSE(60553)\n(与超大球互斥)",
             fillcolor="#ffb090", color="#cc3300", penwidth=2.5];
    }

    subgraph cluster_derivatives {
        label="派生招";
        style="rounded,filled"; fillcolor="#fff0f0"; color="#cc6666";

        d3007 [label="⏩ 横扫近\nID 3007\n(Repeat)", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3011 [label="⏩ 180°回身\nID 3011\n(Repeat)", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3002 [label="⏩ 重击追击\nID 3002\n(Repeat)", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3023 [label="🎭 远程追击\nID 3023\n(Repeat / Final 视情境)", fillcolor="#ffddee", color="#cc6699", penwidth=2.5];
        d3019 [label="⏩ 乱舞派生\nID 3019\n(Repeat)", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3033 [label="⏩ 飞扑追击\nID 3033\n(Repeat)", fillcolor="#ffd8d8", color="#cc3333", penwidth=2];
        d3039 [label="🛑 飞扑终结\nID 3039\n(Final, 硬性收尾)", fillcolor="#ffb8b8", color="#cc3333", penwidth=2.5];
        d3035 [label="🛑 长吼叫收尾\nID 3035/3036/3037\n(3 种 Final 变体, rand 抽签)", fillcolor="#ff9090", color="#cc3333", penwidth=3];
    }

    { rank=sink;
    aa [label="🌬 AfterAttack", shape=note, fillcolor="#e8f8ff"];
    }

    // ==================== 权重抽签边（激进版权重）====================
    hub -> n20 [label="w:0~100"];
    hub -> n21 [label="w:0~100"];
    hub -> n22 [label="w:50~100"];
    hub -> n23 [label="w:0~100"];
    hub -> n24 [label="w:0~200"];

    hub -> n35 [label="w:0~200", color="#cc9966"];
    hub -> n36 [label="w:0~200", color="#cc9966"];
    hub -> n37 [label="w:0~200", color="#cc5533", penwidth=1.5];

    hub -> n15 [label="w:200 (dist>10)", color="#3366cc"];
    hub -> n18 [label="🟣 HP<0.2 无 60585\nSE 强制 处决", color="#8833cc", penwidth=2.5];
    hub -> n38 [label="🟣 HasSE(60553)\nSE 强制 大招", color="#cc0000", penwidth=3];

    hub -> n40 [label="w:50", color="#4477bb"];
    hub -> n41 [label="w:0~75", color="#4477bb"];
    hub -> n42 [label="w:50~75", color="#4477bb"];
    hub -> n45 [label="w:0~200", color="#4477bb"];

    // 红刀链入口
    hub -> n30 [label="🟣 60551 无 60565", color="#8833cc", penwidth=2.5];
    hub -> n16 [label="🟣 60566 + dist>12.5", color="#8833cc", penwidth=2.5];
    hub -> n17 [label="🟣 60566 + dist≤12.5", color="#8833cc", penwidth=2.5];

    // ==================== SE 强制转移 ====================
    n30 -> hub [label="🟣 加60565 → slot31", color="#8833cc", penwidth=2, constraint=false];
    n31 -> hub [label="🟣 加60567 → slot32", color="#8833cc", penwidth=2, constraint=false];
    n32 -> hub [label="🟣 清SE，回归", color="#8833cc", penwidth=2, style=dashed, constraint=false];
    n15 -> hub [label="🟣 加60566", color="#8833cc", penwidth=2, constraint=false];
    n17 -> hub [label="🟣 加60553", color="#8833cc", penwidth=2, style=dashed, constraint=false];

    // ==================== Interrupt append 边 ====================
    n20 -> d3002 [label="🔥 5025帧近", color="#cc3333", penwidth=2];
    n20 -> n21   [label="🔥 5025帧中", color="#cc3333", penwidth=2];
    n21 -> d3002 [label="🔥 5026帧近", color="#cc3333", penwidth=2];
    n21 -> n21   [label="🔥 5026帧中\n🛑Final(3001)", color="#cc3333", penwidth=2.5];

    n22 -> d3007 [label="🔥 5027帧近", color="#cc3333", penwidth=2];
    n22 -> d3011 [label="🔥 5029帧中\n(180°回身)", color="#cc3333", penwidth=2];

    n23 -> d3002 [label="🔥 5030帧", color="#cc3333", penwidth=2];

    // P2 特有 Interrupt
    n35 -> d3023 [label="🔥 5033帧\n远距 40m", color="#cc3333", penwidth=2];
    n36 -> d3023 [label="🔥 5034帧\n(乱舞→远程)", color="#cc3333", penwidth=2];
    n36 -> d3019 [label="🔥 5036帧\n60545 + 无60555\n→ 3019 派生", color="#cc3333", penwidth=2];
    n37 -> d3033 [label="🔥 5035帧", color="#cc3333", penwidth=2];
    n37 -> d3039 [label="🔥 5036帧\n60545+60555\n→ 终结", color="#cc3333", penwidth=2];

    // 长吼叫的 Interrupt（大招接续）
    n38 -> d3035 [label="🔥 5037帧\n分距离/rand → 3035/3036/3037", color="#cc0000", penwidth=2];

    // 60592 (蓄力打断) 特殊反应
    n38 -> d3023 [label="🔥 60592\n蓄力打断 → 前方45m\n改打 3023 或重起 slot21", color="#cc3333", penwidth=2, style=dashed];

    // ==================== AfterAttack 汇聚 ====================
    n20 -> aa [style=dashed, color="#888888"];
    n21 -> aa [style=dashed, color="#888888"];
    n22 -> aa [style=dashed, color="#888888"];
    n23 -> aa [style=dashed, color="#888888"];
    n24 -> aa [style=dashed, color="#888888"];
    n30 -> aa [style=dashed, color="#888888"];
    n31 -> aa [style=dashed, color="#888888"];
    n32 -> aa [style=dashed, color="#888888"];
    n15 -> aa [style=dashed, color="#888888"];
    n16 -> aa [style=dashed, color="#888888"];
    n17 -> aa [style=dashed, color="#888888"];
    n18 -> aa [style=dashed, color="#888888"];
    n35 -> aa [style=dashed, color="#888888"];
    n36 -> aa [style=dashed, color="#888888"];
    n37 -> aa [style=dashed, color="#888888"];
    n38 -> aa [style=dashed, color="#888888"];
    d3007 -> aa [style=dashed, color="#888888"];
    d3011 -> aa [style=dashed, color="#888888"];
    d3002 -> aa [style=dashed, color="#888888"];
    d3023 -> aa [style=dashed, color="#888888"];
    d3019 -> aa [style=dashed, color="#888888"];
    d3033 -> aa [style=dashed, color="#888888"];
    d3039 -> aa [style=dashed, color="#888888"];
    d3035 -> aa [style=dashed, color="#888888"];
    n40 -> aa [style=dashed, color="#888888"];
    n41 -> aa [style=dashed, color="#888888"];
    n42 -> aa [style=dashed, color="#888888"];
    n45 -> aa [style=dashed, color="#888888"];

    subgraph cluster_legend {
        label="图例"; style="rounded,dashed"; color="#aaaaaa";
        rank=sink;
        leg1 [label="■ 黑实线 = 权重抽签", shape=plaintext];
        leg2 [label="━ 粗红线 = Interrupt append", shape=plaintext, fontcolor="#cc3333"];
        leg3 [label="🟣 紫粗线 = SE 强制 (combo chain)", shape=plaintext, fontcolor="#8833cc"];
        leg4 [label="⚡ 深红粗线 = 大招 SE 强制", shape=plaintext, fontcolor="#cc0000"];
        leg5 [label="┈ 虚灰线 = 打完 → AfterAttack", shape=plaintext];
    }
}
